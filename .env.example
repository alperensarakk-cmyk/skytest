# Groq API key — https://console.groq.com/keys adresinden al
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sunucu port (Render/Railway otomatik PORT verir, değiştirme)
PORT=3000

# İzin verilen origin'ler (virgülle ayır, prod'da Flutter app bundle ID veya domain yaz)
# Geliştirme için * bırakabilirsin
ALLOWED_ORIGINS=*
